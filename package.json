{
  "name": "agents-context-turso",
  "version": "1.0.0",
  "description": "Agent memory and context database on Turso with hybrid retrieval, MCP server, CLI, and evaluation harness.",
  "license": "ISC",
  "private": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "bin": {
    "context-cli": "dist/cli.js",
    "context-mcp": "dist/mcp.js"
  },
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "setup": "ts-node src/setup.ts",
    "eval:retrieval": "ts-node src/evaluate.ts",
    "dashboard:api": "ts-node src/dashboardApi.ts",
    "dashboard:dev": "npm --prefix dashboard run dev",
    "dashboard:build": "npm --prefix dashboard run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "agents",
    "turso",
    "context",
    "libsql",
    "vector-search",
    "mcp",
    "rag"
  ],
  "author": "",
  "dependencies": {
    "@google/genai": "^1.45.0",
    "@libsql/client": "^0.17.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
