{
  "name": "agents-context-elastic",
  "version": "2.0.0",
  "description": "Agent memory and context database on Elasticsearch with native hybrid retrieval (kNN + BM25), CLI, and evaluation harness.",
  "license": "ISC",
  "private": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "bin": {
    "context-cli": "dist/cli.js"
  },
  "engines": {
    "bun": ">=1"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "setup": "bun src/scripts/setup.ts",
    "eval:retrieval": "bun src/eval/evaluate.ts",
    "eval:seed": "bun src/eval/evaluate.ts --seed true",
    "eval:full": "bun src/eval/evaluate.ts --seed true --cleanup true",
    "eval:ablation": "bun src/eval/evaluate.ts --ablation true",
    "dashboard:api": "bun src/dashboardApi.ts",
    "dashboard:dev": "bun run --cwd dashboard dev",
    "dashboard": "bun run --parallel dashboard:api dashboard:dev",
    "dashboard:build": "bun run --cwd dashboard build",
    "sync:notion": "bun src/notionSync.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "oxlint src",
    "link": "bun run build && bun link",
    "prepublishOnly": "bun run clean && bun run build"
  },
  "keywords": [
    "agents",
    "elasticsearch",
    "context",
    "vector-search",
    "hybrid-search",
    "rag",
    "bm25",
    "knn"
  ],
  "author": "",
  "dependencies": {
    "@elastic/elasticsearch": "^8.17.0",
    "@google/genai": "^1.45.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@repomix/tree-sitter-wasms": "^0.1.16",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "web-tree-sitter": "^0.26.7"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "oxlint": "^1.56.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
