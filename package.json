{
  "name": "agents-context-turso",
  "version": "1.0.0",
  "description": "Agent memory and context database on Turso with hybrid retrieval, CLI, and evaluation harness.",
  "license": "ISC",
  "private": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "bin": {
    "context-cli": "dist/cli.js"
  },
  "engines": {
    "bun": ">=1"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "setup": "bun src/setup.ts",
    "eval:retrieval": "bun src/evaluate.ts",
    "dashboard:api": "bun src/dashboardApi.ts",
    "dashboard:dev": "bun --cwd dashboard run dev",
    "dashboard": "bun run --parallel dashboard:api dashboard:dev",
    "dashboard:build": "bun --cwd dashboard run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "oxlint src",
    "link": "bun run build && bun link",
    "prepublishOnly": "bun run clean && bun run build"
  },
  "keywords": [
    "agents",
    "turso",
    "context",
    "libsql",
    "vector-search",
    "rag"
  ],
  "author": "",
  "dependencies": {
    "@google/genai": "^1.45.0",
    "@libsql/client": "^0.17.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "oxlint": "^1.56.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
