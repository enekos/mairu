{
  "safe_keys": [
    "timestamp", "severity", "traceId", "spanId", "transactionName",
    "resource", "labels", "container_name", "namespace_name",
    "jsonPayload", "id", "status", "message", "request",
    "environment", "region", "zone", "version", "commitSha", "buildId"
  ],
  "redact_keys": [
    "email", "phone", "phoneNumber", "mobileNumber", "firstName", "lastName",
    "fullName", "name", "givenName", "familyName", "middleName",
    "address", "street", "streetAddress", "city", "postalCode", "zipCode", "country",
    "birthDate", "birthday", "dob", "dateOfBirth",
    "ssn", "socialSecurityNumber", "nationalId", "nationalInsuranceNumber",
    "dni", "nie", "nif", "passport", "passportNumber",
    "driverLicense", "driversLicenseNumber",
    "iban", "bic", "swift", "sortCode", "routingNumber",
    "bankAccount", "accountNumber",
    "taxId", "steuerId", "vatId", "vatNumber",
    "ipAddress", "clientIp", "remoteIp", "remoteAddr", "xForwardedFor",
    "macAddress", "deviceId", "fingerprint",
    "userAgent",
    "latitude", "longitude", "coordinates", "geo", "location",
    "cv", "cvText", "resumeText", "coverLetter",
    "creditCard", "cardNumber", "cvv", "cardCvv", "cardCvc", "cardExpiry",
    "password", "passwordHash", "token", "apiKey", "secret",
    "authorization", "auth",
    "accessToken", "refreshToken", "idToken", "sessionId", "sessionToken",
    "cookie", "setCookie",
    "salary", "compensation", "earnings", "income",
    "gender", "ethnicity", "religion", "nationality", "maritalStatus"
  ],
  "content_patterns": {
    "email":           "[\\w.+-]+@[\\w-]+\\.[\\w.-]+",
    "phone_e164":      "\\+\\d{7,15}",
    "phone_us":        "\\(?\\d{3}\\)?[-. ]\\d{3}[-. ]\\d{4}",
    "iban":            "[A-Z]{2}\\d{2}[A-Z0-9]{11,30}",
    "credit_card":     "\\b(?:\\d[ -]?){13,19}\\b",
    "uuid":            "\\b[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}\\b",
    "eth_address":     "\\b0x[a-fA-F0-9]{40}\\b",
    "google_oauth":    "\\bya29\\.[A-Za-z0-9_-]{20,}",
    "azure_conn_str":  "DefaultEndpointsProtocol=[^;\\s]+;AccountName=[^;\\s]+;AccountKey=[^;\\s]+",
    "jwt":             "eyJ[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+",
    "ipv4":            "\\b(?:\\d{1,3}\\.){3}\\d{1,3}\\b",
    "ipv6":            "\\b(?:[0-9a-fA-F]{1,4}:){7}[0-9a-fA-F]{1,4}\\b",
    "bearer":          "Bearer\\s+[A-Za-z0-9_.\\-~+/=]+",
    "ssn_us":          "\\b\\d{3}-\\d{2}-\\d{4}\\b",
    "nino_uk":         "\\b[A-Z]{2}\\d{6}[A-D]\\b",
    "vat_eu":          "\\b(?:AT|BE|BG|CY|CZ|DE|DK|EE|EL|ES|FI|FR|HR|HU|IE|IT|LT|LU|LV|MT|NL|PL|PT|RO|SE|SI|SK|XI)[0-9A-Z]{8,12}\\b",
    "mac_address":     "\\b(?:[0-9a-fA-F]{2}[:-]){5}[0-9a-fA-F]{2}\\b",
    "latlong":         "-?\\d{1,3}\\.\\d{3,},\\s*-?\\d{1,3}\\.\\d{3,}",
    "aws_access_key":  "\\bAKIA[0-9A-Z]{16}\\b",
    "gcp_api_key":     "\\bAIza[0-9A-Za-z_-]{35}\\b",
    "github_token":    "\\bgh[pousr]_[A-Za-z0-9]{36,}\\b",
    "slack_token":     "xox[baprs]-[A-Za-z0-9-]{10,}",
    "stripe_key":      "\\b(?:sk|pk|rk)_(?:live|test)_[0-9a-zA-Z]{20,}\\b",
    "private_key_pem": "-----BEGIN[ A-Z]*PRIVATE KEY-----",
    "basic_auth_url":  "https?://[^\\s:/@]+:[^\\s@/]+@"
  },
  "max_safe_string_length": 2000,
  "service_field": "resource.labels.container_name"
}
