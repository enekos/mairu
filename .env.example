ELASTIC_URL=http://localhost:9200
# ELASTIC_USERNAME=elastic
# ELASTIC_PASSWORD=changeme

GEMINI_API_KEY=your_gemini_api_key

# Embedding configuration
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIM=3072

# Set true only for local/offline testing
ALLOW_ZERO_EMBEDDINGS=false

# Optional
DASHBOARD_API_PORT=8787

# ── Elasticsearch fine-tuning ──────────────────────────────────────────────────

# BM25 parameters (applied at index creation time — requires `bun run setup` after changing)
# ES_BM25_K1=1.2           # Term frequency saturation (higher = more weight to repeated terms)
# ES_BM25_B=0.75           # Document length normalization (0 = no normalization, 1 = full)

# Recency decay function
# ES_RECENCY_SCALE=30d     # Half-life: score halves at this age (e.g., 7d, 30d, 90d)
# ES_RECENCY_DECAY=0.5     # Decay factor at scale distance (0-1)

# Default search behavior (overridable per-query via CLI flags or API params)
# ES_DEFAULT_FUZZINESS=auto  # Typo tolerance: auto, 0, 1, 2
# ES_PHRASE_BOOST=2.0        # Boost for exact phrase matches (0 = disabled)

# Synonyms (semicolon-separated Lucene synonym rules, applied at index creation time)
# ES_SYNONYMS=auth,authentication,authn;db,database;k8s,kubernetes;js,javascript;ts,typescript

# ── Optional adaptive retrieval policy (online RL-style tuning) ─────────────────
# RL_ADAPTIVE_ENABLED=false
# RL_PROJECT_ALLOWLIST=my-project,another-project
# RL_EPSILON=0.15
# RL_WARMUP_SAMPLES=5
# RL_POLICY_STORE_PATH=.contextfs-rl-policies.json
# RL_EVENT_LOG_PATH=.contextfs-rl-events.jsonl
